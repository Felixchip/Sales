{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": ["nodejs"],
  "build": {
    "steps": {
      "build": {
        "commands": [
          "cd frontend && npm install && npm run build"
        ]
      }
    }
  },
  "deploy": {
    "startCommand": "gunicorn --bind 0.0.0.0:$PORT src.app:app"
  }
}
